<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | BrandLogo Bauhaus</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Outfit', 'sans-serif'],
            },
          },
        },
      };
    </script>
    <style>
      body {
        background-color: #F0F0F0;
        background-image: radial-gradient(#121212 1px, transparent 1px);
        background-size: 32px 32px;
      }
      .bauhaus-triangle {
        clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
      }
    </style>
  </head>
  <body class="text-[#121212] min-h-screen flex items-center justify-center p-4">
    
    <div class="relative w-full max-w-4xl flex flex-col md:flex-row-reverse border-4 border-[#121212] bg-white shadow-[12px_12px_0px_0px_rgba(18,18,18,1)] overflow-hidden">
      
      <div class="w-full md:w-5/12 bg-[#F0C020] border-b-4 md:border-b-0 md:border-l-4 border-[#121212] p-8 flex flex-col justify-center items-center relative overflow-hidden">
        <div class="absolute top-[-40px] right-[-40px] w-48 h-48 rounded-full border-4 border-[#121212] bg-[#1040C0]"></div>
        <div class="absolute bottom-[-20px] left-[-20px] w-24 h-24 border-4 border-[#121212] bg-[#D02020] rotate-45"></div>
        
        <div class="relative z-10 text-center">
          <div class="flex justify-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-full bg-[#1040C0] border-2 border-[#121212]"></div>
            <div class="w-8 h-8 bg-[#D02020] border-2 border-[#121212]"></div>
          </div>
          <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tighter leading-none mb-4">
            WELCOME <br/> BACK
          </h1>
          <p class="font-bold uppercase tracking-widest text-xs border-t-2 border-[#121212] pt-2 inline-block">
            Social Media Platform
          </p>
        </div>
      </div>

      <div class="w-full md:w-7/12 p-8 md:p-16 bg-white relative">
        <div class="hidden md:block absolute top-10 right-10 w-4 h-4 rounded-full bg-[#D02020]"></div>
        
        <form action="/login" method="post" class="relative z-10">
          <div class="mb-10">
            <h2 class="text-sm font-black uppercase tracking-[0.3em] text-gray-500 mb-2">Login</h2>
            <div class="h-2 w-16 bg-[#1040C0]"></div>
          </div>

          <div class="mb-6">
            <label for="email" class="block text-xs font-black uppercase tracking-widest mb-2 text-[#121212]">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full px-4 py-4 border-4 border-[#121212] rounded-none focus:outline-none focus:bg-[#F0C020]/10 transition-colors font-bold placeholder:text-gray-300"
              placeholder="STUDENT@BAUHAUS.EDU"
              required
            />
          </div>

          <div class="mb-8">
            <div class="flex justify-between items-end mb-2">
              <label for="password" class="block text-xs font-black uppercase tracking-widest text-[#121212]">Password</label>
              <a href="#" class="text-[10px] font-black uppercase tracking-tighter text-[#1040C0] hover:bg-[#1040C0] hover:text-white px-1">Forgot?</a>
            </div>
            <input
              type="password"
              id="password"
              name="password"
              class="w-full px-4 py-4 border-4 border-[#121212] rounded-none focus:outline-none focus:bg-[#D02020]/10 transition-colors font-bold placeholder:text-gray-300"
              placeholder="••••••••"
              required
            />
          </div>

          <button
            type="submit"
            class="group relative w-full bg-[#1040C0] text-white font-black uppercase tracking-widest py-5 px-6 border-4 border-[#121212] shadow-[8px_8px_0px_0px_rgba(18,18,18,1)] transition-all active:translate-x-[4px] active:translate-y-[4px] active:shadow-none"
          >
            <span class="relative z-10">Log in</span>
            <div class="absolute top-2 right-2 w-2 h-2 rounded-full bg-[#F0C020] border border-black opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </button>
        </form>

        <p class="mt-12 text-center md:text-left text-xs font-bold uppercase tracking-tight">
          Don't have account? 
          <a href="/signup" class="text-[#D02020] underline decoration-2 underline-offset-4 hover:bg-[#D02020] hover:text-white px-1 transition-all">
            Create Account
          </a>
        </p>
      </div>
    </div>

  </body>
</html>