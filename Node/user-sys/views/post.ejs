<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create | Bauhaus Studio</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Outfit', 'sans-serif'],
            },
          },
        },
      };
    </script>
    <style>
      body {
        background-color: #F0F0F0;
        background-image: radial-gradient(#121212 1px, transparent 1px);
        background-size: 24px 24px;
      }
      .bauhaus-triangle {
        clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
      }
    </style>
  </head>
  <body class="text-[#121212] font-sans min-h-screen py-12 px-4">
    <div class="mx-auto max-w-6xl">
      
      <!-- <div class="mb-12 border-b-8 border-[#121212] pb-6 flex flex-col md:flex-row justify-between items-end">
        <div>
          <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-[0.85]">
            SHARE <span class="text-[#1040C0]">YOUR</span>  VISION
          </h1>
        </div>
        <div class="mt-6 md:mt-0 text-right">
          <p class="font-bold uppercase tracking-widest text-sm border-2 border-black p-2 inline-block bg-[#F0C020]">
            Manifesto No. 04
          </p>
        </div>
      </div> -->

      <div class="grid gap-0 lg:grid-cols-12 border-4 border-[#121212] bg-white shadow-[16px_16px_0px_0px_black] overflow-hidden">
        
        <section class="lg:col-span-7 p-8 md:p-12 border-b-4 lg:border-b-0 lg:border-r-4 border-[#121212]">
          <form class="space-y-8" action="/post" method="post" enctype="multipart/form-data">
            
            <div class="relative">
              <label class="text-xs font-black uppercase tracking-[0.3em] mb-3 block text-[#121212]">Post Title</label>
              <input
                name="title"
                type="text"
                placeholder="ENTER TITLE"
                class="w-full bg-transparent border-b-4 border-black py-4 text-2xl font-bold uppercase tracking-tighter outline-none focus:border-[#D02020] transition-colors placeholder:text-gray-300"
              />
            </div>

            <div>
              <label class="text-xs font-black uppercase tracking-[0.3em] mb-3 block text-[#121212]">Image (URL)</label>
              <input
                type="file"
                name="imgurl"
                placeholder="HTTPS://SOURCE.IMG"
                class="w-full bg-white border-4 border-black p-4 font-bold outline-none focus:bg-[#1040C0]/5 transition-all shadow-[4px_4px_0px_0px_black]"
              />
            </div>

            <div>
              <label class="text-xs font-black uppercase tracking-[0.3em] mb-3 block text-[#121212]">The Manifesto (Message)</label>
              <textarea
                name="description"
                rows="4"
                placeholder="DESCRIBE THE FUNCTION..."
                class="w-full bg-white border-4 border-black p-4 font-bold outline-none focus:bg-[#F0C020]/5 transition-all shadow-[4px_4px_0px_0px_black] resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="group relative w-full bg-[#D02020] text-white font-black uppercase tracking-widest py-6 border-4 border-[#121212] shadow-[8px_8px_0px_0px_black] transition-all active:translate-x-[4px] active:translate-y-[4px] active:shadow-none hover:bg-[#b01a1a]"
            >
              <span class="relative z-10 text-xl">Post</span>
            </button>
          </form>
        </section>

        <aside class="lg:col-span-5 bg-[#1040C0] relative min-h-[400px] flex items-center justify-center overflow-hidden">
          <div class="relative w-64 h-64 border-4 border-black bg-white shadow-[12px_12px_0px_0px_black] flex items-center justify-center">
             <div class="absolute top-4 left-4 w-12 h-12 rounded-full bg-[#D02020] border-2 border-black"></div>
             <div class="absolute bottom-6 right-6 w-20 h-20 bg-[#F0C020] border-2 border-black bauhaus-triangle"></div>
             <div class="w-1 h-32 bg-black rotate-45"></div>
             <div class="w-1 h-32 bg-black -rotate-45"></div>
             
             <p class="absolute bottom-2 left-2 text-[8px] font-black uppercase tracking-widest">Construct 2026</p>
          </div>
          
          <div class="absolute -top-10 -right-10 w-40 h-40 border-4 border-black bg-[#F0C020] rounded-full opacity-50"></div>
          <div class="absolute bottom-10 -left-20 w-64 h-8 bg-black rotate-12"></div>
        </aside>

      </div>

      <div class="mt-8 flex justify-center">
        <a href="/profile" class="font-black uppercase tracking-widest text-xs border-b-2 border-black hover:text-[#1040C0] hover:border-[#1040C0] transition-colors">
          ← Return to Profile
        </a>
      </div>
    </div>
  </body>
</html>