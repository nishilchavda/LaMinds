<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile | Bauhaus Collective</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Outfit', 'sans-serif'],
            },
          },
        },
      };
    </script>
    <style>
      body {
        background-color: #F0F0F0;
        background-image: radial-gradient(#121212 1.5px, transparent 1.5px);
        background-size: 40px 40px;
      }
      .triangle {
        clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
      }
    </style>
  </head>
  <body class="text-[#121212] font-sans">
    <div class="min-h-screen py-12 px-4">

      <div class="mx-auto max-w-5xl">
        
        <header class="relative flex flex-col md:flex-row border-4 border-[#121212] bg-white shadow-[12px_12px_0px_0px_black] mb-16">
          
          <div class="w-full md:w-64 bg-[#D02020] p-6 flex flex-col items-center justify-center border-b-4 md:border-b-0 md:border-r-4 border-[#121212]">
            <div class="relative group">
               <img
                class="h-50 w-50 border-4 border-[#121212] rounded-full object-cover group-hover:grayscale-0 transition-all duration-300 shadow-[6px_6px_0px_0px_black]"
                src="<%= user.image %>"
                alt="user"
              />
            </div>
          </div>

          <div class="flex-1 p-8 bg-white relative">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b-4 border-[#121212] pb-6 mb-6">
              <div>
                <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none mb-2">
                  <%= user.fullname %>
                </h1>
                <p class="text-[#1040C0] font-black lowercase tracking-widest text-sm"><%= user.email %></p>
              </div>
              
              <div class="flex gap-4">
                  <a href="/editprofile">
                    <button  class="bg-[#1040C0] text-white border-2 border-[#121212] px-4 py-2 font-black uppercase tracking-widest text-xs shadow-[4px_4px_0px_0px_black] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all">
                      Edit
                    </button>
                  </a>
                <a href="/logout" class="bg-white text-[#D02020] border-2 border-[#D02020] px-4 py-2 font-black uppercase tracking-widest text-xs shadow-[4px_4px_0px_0px_#D02020] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all">
                  Logout
                </a>
              </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="bg-[#F0C020] border-2 border-[#121212] p-3 shadow-[4px_4px_0px_0px_black]">
                <p class="text-[10px] font-black uppercase opacity-60">Username</p>
                <p class="font-bold text-sm">@<%= user.username %></p>
              </div>
              <div class="bg-white border-2 border-[#121212] p-3 shadow-[4px_4px_0px_0px_black]">
                <p class="text-[10px] font-black uppercase opacity-60">Mobile</p>
                <p class="font-bold text-sm">+91 <%= user.phone %></p>
              </div>
              <div class="bg-white border-2 border-[#121212] p-3 shadow-[4px_4px_0px_0px_black]">
                <p class="text-[10px] font-black uppercase opacity-60">Posts</p>
                <p class="font-bold text-sm">10</p>
              </div>
              <a href="/post" class="bg-[#D02020] border-2 border-[#121212] p-3 shadow-[4px_4px_0px_0px_black] flex items-center justify-center group hover:bg-[#1040C0] transition-colors">
                 <p class="text-white font-black uppercase tracking-tighter text-center">New Post +</p>
              </a>
            </div>
          </div>
        </header>

        <section>
          <div class="flex items-center gap-4 mb-8">
            <h3 class="text-2xl font-black uppercase tracking-tighter">Recent Post</h3>
            <div class="h-1 flex-1 bg-[#121212]"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <% user.posts.map((data) =>{ %>
            <div class="h-96 relative group">
              <article class="relative group">
              <div class="absolute inset-0 bg-[#1040C0] border-4 border-[#121212] translate-x-4 translate-y-4 -z-10"></div>
              
              <div class="bg-white border-4 border-[#121212] overflow-hidden">
                <div class="h-auto bg-gray-200 border-b-4 border-[#121212] overflow-hidden">
                  <img
                    src="/uploads/<%= data.imgurl %>" 
                   
                    alt="imge"
                    class=" w-full object-cover group-hover:grayscale-0 transition-all duration-500 scale-105 group-hover:scale-100"
                  />
                </div>

                <div class="p-8">
                
                  
                  <h2 class="text-3xl font-black uppercase tracking-tighter leading-tight mb-4">
                    <%= data.title %>
                  </h2>
                  <p class="text-gray-600 font-medium leading-relaxed mb-6">
                    <%= data.description %>
                  </p>
                </div>
              </div>
            </article>
            <a href="/delete/<%= data._id %>" class="text-3xl bg-red-600 w-10 h-10  text-center text-white absolute top-2 right-2 border-2  border-r-4 border-b-4 border-[#121212] hidden group-hover:block z-10">
              &times;
            </a>
            </div>

            <% }) %>
            </div>
        </section>
      </div>

    </div>
  </body>
</html>